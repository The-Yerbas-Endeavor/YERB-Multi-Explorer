extends layout

block content
  include ./includes/common.pug
  link(rel='stylesheet', href='/css/modern-dashboard.css')
  script.
    var setting_maxTxCount = parseInt("#{settings.api_page.public_apis.ext.getlasttxs.max_items_per_query}");
    var setting_txPerPage = parseInt("#{settings.index_page.transaction_table.items_per_page}");
    var displayLengthMax = Math.min(setting_maxTxCount, setting_txPerPage);

    function formatDashboardNumber(value, decimals) {
      var number = Number(value);
      if (!Number.isFinite(number)) return '—';
      return number.toLocaleString('en-US', {
        minimumFractionDigits: decimals || 0,
        maximumFractionDigits: decimals || 0
      });
    }

    function firstValue(object, keys, fallback) {
      for (var i = 0; i < keys.length; i++) {
        if (object[keys[i]] !== undefined && object[keys[i]] !== null)
          return object[keys[i]];
      }
      return fallback;
    }

    function setDashboardValue(id, value) {
      var node = document.getElementById(id);
      if (node) node.textContent = value;
    }

    function updateDashboardSummary() {
      $.ajax({
        url: '/ext/getsummary',
        headers: { Accept: 'application/json, text/javascript, */*; q=0.01' },
        success: function(summary) {
          var height = firstValue(summary, ['blockcount', 'blockCount', 'height'], null);
          var supply = firstValue(summary, ['supply', 'moneySupply', 'circulatingSupply'], null);
          var difficulty = firstValue(summary, ['difficulty'], null);
          var hashrate = firstValue(summary, ['hashrate', 'networkHashrate', 'nethash'], null);
          var connections = firstValue(summary, ['connections', 'peers'], null);
          var lastPrice = firstValue(summary, ['lastPrice', 'last_price', 'price'], null);
          var masternodes = firstValue(summary, ['masternodeCountOnline', 'masternodes'], null);

          setDashboardValue('dash-height', height == null ? '—' : formatDashboardNumber(height));
          setDashboardValue('dash-supply', supply == null ? '—' : formatDashboardNumber(supply, 2));
          setDashboardValue('dash-difficulty', difficulty == null ? '—' : formatDashboardNumber(difficulty, 4));
          setDashboardValue('dash-hashrate', hashrate == null ? '—' : formatDashboardNumber(hashrate, 2));
          setDashboardValue('dash-peers', connections == null ? '—' : formatDashboardNumber(connections));
          setDashboardValue('dash-price', lastPrice == null ? '—' : formatDashboardNumber(lastPrice, 8));
          setDashboardValue('dash-masternodes', masternodes == null ? '—' : formatDashboardNumber(masternodes));
          setDashboardValue('dash-updated', new Date().toLocaleTimeString());
        }
      });
    }

    $(document).ready(function() {
      var recentTable = $('#recent-table').DataTable({
        autoWidth: false,
        searching: false,
        ordering: false,
        responsive: false,
        lengthChange: true,
        processing: true,
        serverSide: true,
        pageLength: displayLengthMax,
        lengthMenu: [5, 10, 25, 50].filter(function(value) { return value <= setting_maxTxCount; }),
        scrollX: true,
        ajax: {
          url: '/ext/getlasttxs/0',
          beforeSend: function(jqXHR, settings) {
            settings.url = settings.url.substring(0, settings.url.indexOf('?')) + '/' + getParameterByName('start', settings.url) + '/' + getParameterByName('length', settings.url) + '/internal';
            return true;
          }
        },
        language: { paginate: { previous: '<', next: '>' } },
        rowCallback: function(row, data) {
          var blockindex = data[0];
          var blockhash = data[1];
          var txhash = data[2];
          var outputs = data[3];
          var amount = Number(data[4]).toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 8, useGrouping: true });
          var amountParts = amount.split('.');
          amount = amountParts[0] + '.<span class="decimal">' + (amountParts[1] || '00') + '</span>';
          var timestamp = data[5];
          $('td:eq(0)', row).html('<a href="/block/' + blockhash + '">' + blockindex + '</a>');
          $('td:eq(1)', row).html('<a href="/tx/' + txhash + '">' + txhash + '</a>').addClass('breakWord');
          $('td:eq(2)', row).html(outputs);
          $('td:eq(3)', row).html(amount);
          $('td:eq(4)', row).html('<span>' + format_unixtime(timestamp) + '</span>');
        },
        drawCallback: function() {
          fixDataTableColumns();
          fixFooterHeightAndPosition();
          enableTooltips();
        }
      });

      updateDashboardSummary();
      setInterval(updateDashboardSummary, 30000);

      var reloadSeconds = parseInt("#{settings.index_page.transaction_table.reload_table_seconds}");
      if (reloadSeconds > 0)
        setInterval(function() { recentTable.ajax.reload(null, false); }, reloadSeconds * 1000);
    });

  .modern-dashboard
    if error !== null
      .alert.alert-danger.alert-dismissible.fade.show(role='alert')
        button.btn-close(type='button', data-bs-dismiss='alert')
        strong #{settings.locale.ex_error}
        div #{error}

    section.dashboard-hero
      h1 #{settings.coin.symbol} Multi-Explorer
      p Explore blocks, transactions, addresses, assets, and markets on the #{settings.coin.name} network.
      form.dashboard-search(method='post', action='/search')
        input(type='text', name='search', autocomplete='off', placeholder='Search by transaction ID, address, block, or asset…', aria-label='Explorer search')
        button(type='submit', aria-label='Search')
          span.fas.fa-search

    .dashboard-grid
      aside.dashboard-column
        section.dashboard-card
          .dashboard-card-header
            h2 Blockchain overview
          .dashboard-card-body.stat-list
            .stat-row
              span.stat-label Current height
              span.stat-value#dash-height —
            .stat-row
              span.stat-label Circulating supply
              span.stat-value#dash-supply —
            .stat-row
              span.stat-label Difficulty
              span.stat-value#dash-difficulty —
            .stat-row
              span.stat-label Network hashrate
              span.stat-value#dash-hashrate —
            .stat-row
              span.stat-label Network
              span.stat-value Mainnet

        section.dashboard-card
          .dashboard-card-header
            h2 Network status
            span
              i.status-dot
              | Connected
          .dashboard-card-body.stat-list
            .stat-row
              span.stat-label Peers
              span.stat-value#dash-peers —
            .stat-row
              span.stat-label Smartnodes online
              span.stat-value#dash-masternodes —
            .stat-row
              span.stat-label Protocol
              span.stat-value 70223
            .stat-row
              span.stat-label Last updated
              span.stat-value#dash-updated —

      main.dashboard-column
        section.dashboard-card
          .dashboard-card-header
            h2 Latest transactions
            a(href='/txs/0') View all
          .dashboard-table-wrap
            table#recent-table.table.table-hover
              thead
                tr
                  th.text-center Block
                  th.text-center Transaction
                  th.text-center Recipients
                  th.text-center Amount (#{settings.coin.symbol})
                  th.text-center Time
              tbody.text-center

        section.dashboard-card
          .dashboard-card-header
            h2 Network activity
            span.stat-label Live summary
          .dashboard-card-body
            .metric-grid
              .metric
                small Block height
                strong#dash-height-secondary Live
              .metric
                small Current price
                strong
                  span#dash-price —
                  |  USDT
            .sparkline(aria-label='Decorative network activity chart')
              span(style='height:35%')
              span(style='height:48%')
              span(style='height:42%')
              span(style='height:66%')
              span(style='height:51%')
              span(style='height:73%')
              span(style='height:58%')
              span(style='height:79%')
              span(style='height:62%')
              span(style='height:86%')
              span(style='height:72%')
              span(style='height:92%')

      aside.dashboard-column
        section.dashboard-card
          .dashboard-card-header
            h2 Explorer shortcuts
          .dashboard-card-body.stat-list
            a.stat-row(href='/richlist')
              span.stat-label Rich list
              span.stat-value →
            a.stat-row(href='/network')
              span.stat-label Network peers
              span.stat-value →
            a.stat-row(href='/masternodes')
              span.stat-label Smartnodes
              span.stat-value →
            a.stat-row(href='/markets')
              span.stat-label Markets
              span.stat-value →
            a.stat-row(href='/info')
              span.stat-label API documentation
              span.stat-value →

        section.dashboard-card
          .dashboard-card-header
            h2 Asset ecosystem
          .dashboard-card-body
            p.stat-label Browse issued assets, transfers, ownership, and market activity as asset indexing is added.
            .metric-grid
              .metric
                small Native asset
                strong #{settings.coin.symbol}
              .metric
                small Explorer
                strong v2.0
