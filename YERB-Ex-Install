#!/usr/bin/env bash
set -Eeuo pipefail

# YERB-Ex-Install
# Fully automated production installer for YERB Multi-Explorer.
# Supports Ubuntu 22.04, 24.04, and 26.x on amd64/arm64.
#
# Interactive:
#   sudo bash YERB-Ex-Install
#
# Non-interactive:
#   sudo env DOMAIN=explorer.example.org \
#     YERB_RPC_USER=explorer \
#     YERB_RPC_PASSWORD='change-me' \
#     ENABLE_HTTPS=1 CERTBOT_EMAIL=admin@example.org \
#     bash YERB-Ex-Install

readonly REPO_URL="${REPO_URL:-https://github.com/The-Yerbas-Endeavor/YERB-Multi-Explorer.git}"
readonly REPO_BRANCH="${REPO_BRANCH:-main}"
readonly APP_USER="${APP_USER:-yerbexplorer}"
readonly APP_GROUP="${APP_GROUP:-$APP_USER}"
readonly APP_HOME="${APP_HOME:-/home/$APP_USER}"
readonly INSTALL_DIR="${INSTALL_DIR:-/var/www/yerb-explorer}"
readonly BACKUP_DIR="${BACKUP_DIR:-/var/backups/yerb-explorer}"
readonly API_HOST="${API_HOST:-127.0.0.1}"
readonly API_PORT="${API_PORT:-3001}"
readonly REDIS_URL="${REDIS_URL:-redis://127.0.0.1:6379}"
readonly YERB_RPC_URL="${YERB_RPC_URL:-http://127.0.0.1:8766}"
readonly MONGODB_URI="${MONGODB_URI:-mongodb://127.0.0.1:27017/yerbas_explorer}"
readonly SYNC_BATCH_SIZE="${SYNC_BATCH_SIZE:-25}"
readonly ENABLE_HTTPS="${ENABLE_HTTPS:-1}"
readonly ENABLE_UFW="${ENABLE_UFW:-1}"
readonly ENABLE_AUTO_UPDATE="${ENABLE_AUTO_UPDATE:-1}"
readonly ENABLE_BACKUPS="${ENABLE_BACKUPS:-1}"
readonly CERTBOT_EMAIL="${CERTBOT_EMAIL:-}"
readonly SKIP_TYPECHECK="${SKIP_TYPECHECK:-1}"
readonly HEALTH_PATH="${HEALTH_PATH:-/api/v1/health}"

DOMAIN="${DOMAIN:-}"
YERB_RPC_USER="${YERB_RPC_USER:-}"
YERB_RPC_PASSWORD="${YERB_RPC_PASSWORD:-}"

log() { printf '\n\033[1;32m==> %s\033[0m\n' "$*"; }
warn() { printf '\n\033[1;33mWARNING: %s\033[0m\n' "$*" >&2; }
die() { printf '\n\033[1;31mERROR: %s\033[0m\n' "$*" >&2; exit 1; }

on_error() {
  local code=$?
  printf '\n\033[1;31mInstallation failed near line %s (exit %s).\033[0m\n' "${BASH_LINENO[0]}" "$code" >&2
  printf 'Logs: journalctl -u nginx -u mongod -u redis-server --no-pager -n 100\n' >&2
  printf 'App:  sudo -iu %s pm2 logs --lines 100 --nostream\n' "$APP_USER" >&2
  exit "$code"
}
trap on_error ERR

require_root() {
  [[ ${EUID} -eq 0 ]] || die "Run with sudo: sudo bash YERB-Ex-Install"
}

check_platform() {
  [[ -r /etc/os-release ]] || die "Cannot identify the operating system."
  # shellcheck disable=SC1091
  source /etc/os-release
  [[ ${ID:-} == ubuntu ]] || die "Ubuntu is required."
  case "${VERSION_ID:-}" in
    22.04|24.04|26.*) ;;
    *) die "Supported versions: Ubuntu 22.04, 24.04, or 26.x. Detected ${PRETTY_NAME:-unknown}." ;;
  esac
  case "$(dpkg --print-architecture)" in
    amd64|arm64) ;;
    *) die "Only amd64 and arm64 are supported." ;;
  esac
}

prompt_config() {
  if [[ -t 0 ]]; then
    [[ -n "$DOMAIN" ]] || read -r -p "Explorer domain: " DOMAIN
    [[ -n "$YERB_RPC_USER" ]] || read -r -p "Yerbas RPC username: " YERB_RPC_USER
    if [[ -z "$YERB_RPC_PASSWORD" ]]; then
      read -r -s -p "Yerbas RPC password: " YERB_RPC_PASSWORD
      printf '\n'
    fi
  fi

  [[ -n "$DOMAIN" ]] || die "DOMAIN is required."
  [[ "$DOMAIN" =~ ^[A-Za-z0-9.-]+$ ]] || die "DOMAIN is invalid."
  [[ -n "$YERB_RPC_USER" ]] || die "YERB_RPC_USER is required."
  [[ -n "$YERB_RPC_PASSWORD" ]] || die "YERB_RPC_PASSWORD is required."
  [[ "$API_PORT" =~ ^[0-9]+$ ]] || die "API_PORT must be numeric."
}

install_base_packages() {
  log "Installing operating-system packages"
  export DEBIAN_FRONTEND=noninteractive
  apt-get update
  apt-get install -y \
    ca-certificates curl gnupg git sudo build-essential jq rsync lsb-release \
    nginx redis-server ufw certbot python3-certbot-nginx
  systemctl enable --now nginx redis-server
  redis-cli ping | grep -qx PONG || die "Redis did not return PONG."
}

install_mongodb() {
  if command -v mongod >/dev/null 2>&1; then
    log "MongoDB is already installed"
  else
    log "Installing MongoDB Community Edition"
    # shellcheck disable=SC1091
    source /etc/os-release
    local mongo_series codename keyring
    mongo_series="8.0"
    codename="${UBUNTU_CODENAME:-$(lsb_release -sc)}"
    keyring="/usr/share/keyrings/mongodb-server-${mongo_series}.gpg"

    curl -fsSL "https://www.mongodb.org/static/pgp/server-${mongo_series}.asc" \
      | gpg --dearmor --yes -o "$keyring"
    printf 'deb [ arch=%s signed-by=%s ] https://repo.mongodb.org/apt/ubuntu %s/mongodb-org/%s multiverse\n' \
      "$(dpkg --print-architecture)" "$keyring" "$codename" "$mongo_series" \
      > "/etc/apt/sources.list.d/mongodb-org-${mongo_series}.list"

    if ! apt-get update || ! apt-get install -y mongodb-org; then
      warn "MongoDB upstream packages are unavailable for $codename. Use an external MONGODB_URI and rerun."
      rm -f "/etc/apt/sources.list.d/mongodb-org-${mongo_series}.list"
      die "MongoDB installation failed."
    fi
  fi

  systemctl enable --now mongod
  systemctl is-active --quiet mongod || die "MongoDB did not start."
}

install_node_pm2() {
  local need_node=1
  if command -v node >/dev/null 2>&1 && [[ "$(node --version)" == v22.* ]]; then
    need_node=0
  fi
  if [[ $need_node -eq 1 ]]; then
    log "Installing Node.js 22"
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    apt-get install -y nodejs
  fi
  [[ "$(node --version)" == v22.* ]] || die "Node.js 22 is required."
  npm install --global pm2
}

create_account() {
  log "Creating dedicated service account"
  getent group "$APP_GROUP" >/dev/null || groupadd --system "$APP_GROUP"
  if ! id "$APP_USER" >/dev/null 2>&1; then
    useradd --system --create-home --home-dir "$APP_HOME" --gid "$APP_GROUP" --shell /bin/bash "$APP_USER"
  fi
  install -d -o "$APP_USER" -g "$APP_GROUP" -m 0755 "$INSTALL_DIR"
  install -d -o "$APP_USER" -g "$APP_GROUP" -m 0750 "$BACKUP_DIR"
}

deploy_source() {
  log "Deploying YERB Multi-Explorer"
  if [[ -d "$INSTALL_DIR/.git" ]]; then
    sudo -u "$APP_USER" git -C "$INSTALL_DIR" fetch --prune origin
    sudo -u "$APP_USER" git -C "$INSTALL_DIR" checkout "$REPO_BRANCH"
    sudo -u "$APP_USER" git -C "$INSTALL_DIR" reset --hard "origin/$REPO_BRANCH"
  elif [[ -n "$(find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 -print -quit)" ]]; then
    die "$INSTALL_DIR is not empty and is not a Git checkout."
  else
    sudo -u "$APP_USER" git clone --branch "$REPO_BRANCH" --depth 1 "$REPO_URL" "$INSTALL_DIR"
  fi
}

write_environment() {
  log "Writing production environment"
  local scheme=http
  [[ "$ENABLE_HTTPS" == 1 ]] && scheme=https
  install -o "$APP_USER" -g "$APP_GROUP" -m 0600 /dev/null "$INSTALL_DIR/.env"
  cat > "$INSTALL_DIR/.env" <<EOF
NODE_ENV=production
API_HOST=$API_HOST
API_PORT=$API_PORT
MONGODB_URI=$MONGODB_URI
REDIS_URL=$REDIS_URL
YERB_RPC_URL=$YERB_RPC_URL
YERB_RPC_USER=$YERB_RPC_USER
YERB_RPC_PASSWORD=$YERB_RPC_PASSWORD
SYNC_BATCH_SIZE=$SYNC_BATCH_SIZE
CORS_ORIGIN=$scheme://$DOMAIN
EOF
  chown "$APP_USER:$APP_GROUP" "$INSTALL_DIR/.env"
  chmod 0600 "$INSTALL_DIR/.env"
}

build_app() {
  log "Installing dependencies and building"
  if [[ -f "$INSTALL_DIR/package-lock.json" ]]; then
    sudo -u "$APP_USER" -H bash -lc "cd '$INSTALL_DIR' && npm ci"
  else
    sudo -u "$APP_USER" -H bash -lc "cd '$INSTALL_DIR' && npm install --package-lock=true"
  fi
  if [[ "$SKIP_TYPECHECK" != 1 ]]; then
    sudo -u "$APP_USER" -H bash -lc "cd '$INSTALL_DIR' && npm run typecheck"
  fi
  sudo -u "$APP_USER" -H bash -lc "cd '$INSTALL_DIR' && npm run build"
  [[ -f "$INSTALL_DIR/apps/api/dist/server.js" ]] || die "API build output is missing."
  [[ -f "$INSTALL_DIR/apps/api/dist/workers/indexer.js" ]] || die "Indexer build output is missing."
  [[ -f "$INSTALL_DIR/apps/web/dist/index.html" ]] || die "Web build output is missing."
}

configure_pm2() {
  log "Configuring PM2 services"
  sudo -u "$APP_USER" -H bash -lc "cd '$INSTALL_DIR' && pm2 delete yerb-explorer-api yerb-explorer-indexer >/dev/null 2>&1 || true"
  sudo -u "$APP_USER" -H bash -lc "cd '$INSTALL_DIR' && pm2 start ecosystem.config.cjs --update-env"
  sudo -u "$APP_USER" -H pm2 save
  env PATH="$PATH:/usr/bin:/usr/local/bin" pm2 startup systemd -u "$APP_USER" --hp "$APP_HOME" >/dev/null
  systemctl daemon-reload
  systemctl enable --now "pm2-$APP_USER"
}

configure_nginx() {
  log "Configuring Nginx"
  cat > "/etc/nginx/sites-available/$DOMAIN" <<EOF
server {
    listen 80;
    listen [::]:80;
    server_name $DOMAIN;
    root $INSTALL_DIR/apps/web/dist;
    index index.html;
    client_max_body_size 2m;

    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    location /api/ {
        proxy_pass http://127.0.0.1:$API_PORT;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location /socket.io/ {
        proxy_pass http://127.0.0.1:$API_PORT;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location /docs {
        proxy_pass http://127.0.0.1:$API_PORT;
        proxy_set_header Host \$host;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location / {
        try_files \$uri \$uri/ /index.html;
    }
}
EOF
  ln -sfn "/etc/nginx/sites-available/$DOMAIN" "/etc/nginx/sites-enabled/$DOMAIN"
  rm -f /etc/nginx/sites-enabled/default
  nginx -t
  systemctl reload nginx
}

configure_firewall() {
  [[ "$ENABLE_UFW" == 1 ]] || return 0
  log "Configuring UFW firewall"
  ufw allow OpenSSH
  ufw allow 'Nginx Full'
  ufw --force enable
}

configure_https() {
  [[ "$ENABLE_HTTPS" == 1 ]] || return 0
  log "Requesting Let's Encrypt certificate"
  local args=(--nginx --non-interactive --agree-tos --redirect -d "$DOMAIN")
  if [[ -n "$CERTBOT_EMAIL" ]]; then
    args+=(--email "$CERTBOT_EMAIL")
  else
    args+=(--register-unsafely-without-email)
  fi
  certbot "${args[@]}"
  systemctl enable --now certbot.timer 2>/dev/null || true
}

install_backup_job() {
  [[ "$ENABLE_BACKUPS" == 1 ]] || return 0
  log "Installing daily backup job"
  cat > /usr/local/sbin/yerb-explorer-backup <<EOF
#!/usr/bin/env bash
set -Eeuo pipefail
stamp=\$(date +%Y%m%d-%H%M%S)
target="$BACKUP_DIR/\$stamp"
mkdir -p "\$target"
cp -a "$INSTALL_DIR/.env" "\$target/.env"
if command -v mongodump >/dev/null 2>&1; then
  mongodump --uri="$MONGODB_URI" --archive="\$target/mongodb.archive" --gzip
fi
tar -czf "$BACKUP_DIR/yerb-explorer-\$stamp.tar.gz" -C "$INSTALL_DIR" ecosystem.config.cjs package.json
rm -rf "\$target"
find "$BACKUP_DIR" -type f -mtime +14 -delete
EOF
  chmod 0750 /usr/local/sbin/yerb-explorer-backup
  cat > /etc/systemd/system/yerb-explorer-backup.service <<EOF
[Unit]
Description=YERB Explorer backup
After=network-online.target mongod.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/yerb-explorer-backup
EOF
  cat > /etc/systemd/system/yerb-explorer-backup.timer <<EOF
[Unit]
Description=Daily YERB Explorer backup

[Timer]
OnCalendar=*-*-* 03:20:00
Persistent=true
RandomizedDelaySec=15m

[Install]
WantedBy=timers.target
EOF
  systemctl daemon-reload
  systemctl enable --now yerb-explorer-backup.timer
}

install_update_job() {
  [[ "$ENABLE_AUTO_UPDATE" == 1 ]] || return 0
  log "Installing weekly automatic update job"
  cat > /usr/local/sbin/yerb-explorer-update <<EOF
#!/usr/bin/env bash
set -Eeuo pipefail
cd "$INSTALL_DIR"
sudo -u "$APP_USER" git fetch --prune origin
local_head=\$(git rev-parse HEAD)
remote_head=\$(git rev-parse "origin/$REPO_BRANCH")
[[ "\$local_head" != "\$remote_head" ]] || exit 0
sudo -u "$APP_USER" git reset --hard "origin/$REPO_BRANCH"
if [[ -f package-lock.json ]]; then
  sudo -u "$APP_USER" -H npm ci
else
  sudo -u "$APP_USER" -H npm install --package-lock=true
fi
sudo -u "$APP_USER" -H npm run build
sudo -u "$APP_USER" -H pm2 restart all --update-env
sudo -u "$APP_USER" -H pm2 save
nginx -t && systemctl reload nginx
EOF
  chmod 0750 /usr/local/sbin/yerb-explorer-update
  cat > /etc/systemd/system/yerb-explorer-update.service <<EOF
[Unit]
Description=Update YERB Multi-Explorer
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/yerb-explorer-update
EOF
  cat > /etc/systemd/system/yerb-explorer-update.timer <<EOF
[Unit]
Description=Weekly YERB Multi-Explorer update

[Timer]
OnCalendar=Sun *-*-* 04:10:00
Persistent=true
RandomizedDelaySec=30m

[Install]
WantedBy=timers.target
EOF
  systemctl daemon-reload
  systemctl enable --now yerb-explorer-update.timer
}

verify_install() {
  log "Verifying installation"
  systemctl is-active --quiet nginx || die "Nginx is not active."
  systemctl is-active --quiet redis-server || die "Redis is not active."
  systemctl is-active --quiet "pm2-$APP_USER" || die "PM2 service is not active."
  local attempts=30
  until curl --fail --silent --show-error "http://127.0.0.1:$API_PORT$HEALTH_PATH" >/tmp/yerb-health.json; do
    attempts=$((attempts - 1))
    [[ $attempts -gt 0 ]] || {
      sudo -u "$APP_USER" -H pm2 logs --lines 100 --nostream || true
      die "API health check failed. Verify MongoDB and Yerbas RPC settings."
    }
    sleep 2
  done
  cat /tmp/yerb-health.json
  printf '\n'
}

print_summary() {
  local scheme=http
  [[ "$ENABLE_HTTPS" == 1 ]] && scheme=https
  log "YERB Multi-Explorer installation complete"
  cat <<EOF
Explorer:        $scheme://$DOMAIN
API health:      $scheme://$DOMAIN$HEALTH_PATH
API docs:        $scheme://$DOMAIN/docs
Install path:    $INSTALL_DIR
Backups:         $BACKUP_DIR
Service account: $APP_USER

Useful commands:
  sudo -iu $APP_USER pm2 status
  sudo -iu $APP_USER pm2 logs --lines 100
  sudo systemctl status nginx redis-server mongod pm2-$APP_USER
  sudo systemctl list-timers 'yerb-explorer-*'
  sudo /usr/local/sbin/yerb-explorer-backup
  sudo /usr/local/sbin/yerb-explorer-update
EOF
}

main() {
  require_root
  check_platform
  prompt_config
  install_base_packages
  install_mongodb
  install_node_pm2
  create_account
  deploy_source
  write_environment
  build_app
  configure_pm2
  configure_nginx
  configure_firewall
  configure_https
  install_backup_job
  install_update_job
  verify_install
  print_summary
}

main "$@"
